# Copy to .env.local (gitignored) for local runs.
# For Cursor Cloud Agents, add the same keys in:
#   Dashboard → Cloud Agents → Secrets (use "Runtime Secret" for the token)

# Slack Bot User OAuth Token (xoxb-…) — required for /epic-estimation-send-slack
SLACK_BOT_TOKEN=

# Optional: skip channel name lookup (recommended for cloud — copy from Slack channel details)
# SLACK_CHANNEL_ID=C0123456789
